{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src/**/*"]
}
