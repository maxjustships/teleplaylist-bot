{
  "name": "telegram-playlist-bot",
  "version": "1.0.0",
  "description": "Telegram bot that allows you to manage playlists. Cloudflare Workers + D1 + Drizzle ORM",
  "main": "src/app.ts",
  "repository": "https://github.com/Borodutch/telegram-bot-template",
  "author": "moody_cookie <reishmax@gmail.com>",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply teleplaylist-bot-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply teleplaylist-bot-db --remote",
    "db:studio": "pnpm drizzle-kit studio",
    "pretty": "prettier --check src",
    "lint": "pnpm pretty && eslint src",
    "test": "vitest",
    "tunnel": "cloudflared tunnel --url http://localhost:8787",
    "set-webhook": "ts-node src/scripts/setWebhook.ts"
  },
  "dependencies": {
    "@fluent/bundle": "^0.19.1",
    "drizzle-orm": "^0.45.1",
    "grammy": "1.40.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260228.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
